# Configuración del Proyecto Cotizador FastAPI
# Copia este archivo a .env y ajusta los valores según tu entorno

# Nombre del proyecto
PROJECT_NAME=Cotizador
PROJECT_VERSION=1.0.0

# URL de la base de datos (opcional - si no se especifica, usa SQLite por defecto)
# DATABASE_URL=sqlite:///data/database.db

# Orígenes permitidos para CORS (separados por comas)
# En desarrollo usa ["*"], en producción especifica los dominios permitidos
BACKEND_CORS_ORIGINS=["*"]

# Clave secreta para seguridad (cambiar en producción)
SECRET_KEY=secret-key-change-in-production

# Entorno: development, staging, production
ENVIRONMENT=development
